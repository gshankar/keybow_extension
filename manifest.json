{
  "manifest_version": 3,
  "name": "Keybow Google Meet Reactions",
  "version": "1.0",
  "description": "Listens for Keybow Numpad keystrokes to instantly trigger Google Meet emoji reactions.",
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Keybow Settings"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
